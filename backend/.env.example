# ─── Ambiente ────────────────────────────────────────────────────────────────
ENVIRONMENT=development

# ─── URLs ─────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# ─── Segurança ────────────────────────────────────────────────────────────────
SECRET_KEY=troque-por-uma-chave-aleatoria-longa
ADMIN_SECRET_KEY=troque-por-outra-chave-aleatoria

# ─── Banco de dados (Docker) ──────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/assistente_ia

# ─── Cache (Docker) ───────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── IA — Groq (gratuito) ─────────────────────────────────────────────────────
# Crie sua chave em: https://console.groq.com
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile

# ─── Email — Resend (gratuito até 3k emails/mês) ─────────────────────────────
# Crie sua chave em: https://resend.com
RESEND_API_KEY=re_...
EMAIL_FROM=Assistente IA <noreply@seudominio.com.br>

# ─── Pagamentos — Mercado Pago ────────────────────────────────────────────────
# Crie suas credenciais em: https://www.mercadopago.com.br/developers
MERCADOPAGO_ACCESS_TOKEN=APP_USR-...
MERCADOPAGO_PUBLIC_KEY=APP_USR-...

# ─── Trial ────────────────────────────────────────────────────────────────────
TRIAL_DIAS=30
